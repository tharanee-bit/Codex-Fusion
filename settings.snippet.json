{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/codex-fusion-userprompt.sh",
            "timeout": 270
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/codex-fusion-stop.sh",
            "timeout": 270
          }
        ]
      }
    ]
  }
}
